PUBLIC_BASE_URL=https://hermes.example.com:10005
CORS_ALLOW_ORIGINS=https://hermes.example.com:10005
STRICT_CONFIG_VALIDATION=false
APP_SHARED_SECRET=dev-shared-secret-change-me-32-bytes
JWT_SECRET=dev-jwt-secret-change-me-32-bytes
JWT_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
BOOTSTRAP_ADMIN_USERNAME=admin
ALLOW_LEGACY_SHARED_SECRET_AUTH=false
MONITORING_TOKEN=
HEALTHCHECK_BASE_URL=https://127.0.0.1:10005
AUTH_RATE_LIMIT_REQUESTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOCKOUT_FAILURES=5
AUTH_LOCKOUT_SECONDS=900
CLIENT_LOG_RATE_LIMIT_REQUESTS=120
CLIENT_LOG_RATE_LIMIT_WINDOW_SECONDS=60
DEPENDENCY_HEALTH_CACHE_SECONDS=5
CONVERSATION_DATABASE_PATH=data/conversations.sqlite3
MAX_CONCURRENT_SESSIONS=8

# Hermes runs on the same host by default.
HERMES_BASE_URL=http://127.0.0.1:8642
HERMES_API_KEY=your-hermes-api-server-key
HERMES_MODEL=hermes-agent
HERMES_TIMEOUT_SECONDS=45
HERMES_MAX_ATTEMPTS=2
HERMES_RETRY_BACKOFF_SECONDS=0.4
HERMES_MAX_TOKENS=500
HERMES_HISTORY_MAX_TURNS=12
HERMES_HISTORY_MAX_CHARS=24000
# Set to empty string to disable the voice-mode system prompt.
HERMES_SYSTEM_PROMPT=语音助手规则：回复将直接朗读，禁止任何Markdown格式。用自然口语短句，每句话不超过40字。回答简洁，控制在100字以内。

DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_ASR_MODEL=fun-asr-realtime
DASHSCOPE_ASR_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/inference
DASHSCOPE_TTS_MODEL=qwen3-tts-flash-realtime
DASHSCOPE_TTS_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
DASHSCOPE_TTS_VOICE=Cherry
DASHSCOPE_TTS_SPEECH_RATE=1.0
DASHSCOPE_CONTROL_TIMEOUT_SECONDS=12
DASHSCOPE_TTS_AUDIO_TIMEOUT_SECONDS=90

USE_MOCK_ASR=false
USE_MOCK_TTS=false
WEBRTC_AUDIO_PREBUFFER_SECONDS=1.0
WEBRTC_ADAPTIVE_BUFFER_ENABLED=true
WEBRTC_AUDIO_PREBUFFER_MIN_SECONDS=0.5
WEBRTC_AUDIO_PREBUFFER_MAX_SECONDS=1.2
WEBRTC_REBUFFER_STEP_SECONDS=0.2
WEBRTC_SESSION_IDLE_TIMEOUT_SECONDS=45
AUTO_VAD_SILENCE_MS=2500
AUTO_VAD_PREROLL_MS=500
BARGE_IN_MIN_CHARS=3
BARGE_IN_COOLDOWN_MS=500
BARGE_IN_ECHO_SIMILARITY=0.62
BARGE_IN_ACOUSTIC_ECHO_SIMILARITY=0.35
SSL_CERT_FILE=../ssl/fullchain.pem
SSL_KEY_FILE=../ssl/privkey.pem

ICE_STUN_URLS=stun:stun.l.google.com:19302
# Recommended for mobile networks and restrictive NAT environments.
ICE_TURN_URLS=turn:hermes.example.com:10004?transport=udp,turn:hermes.example.com:10004?transport=tcp
ICE_TURN_USERNAME=replace-with-turn-user
ICE_TURN_CREDENTIAL=replace-with-turn-password
